# API URLs
API_BASE_URL=http://vsbackend.test
MODEL_DOWNLOAD_URL=https://huggingface.co/ggerganov/whisper.cpp/resolve/main/ggml-base.bin

# App Configuration
APP_ENV=development
DEBUG_MODE=true

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=replace_with_supabase_anon_key

# Speaker analysis (offline)
SPEAKER_MODEL_PATH=asset:assets/models/conformer_tisid_small.tflite
SPEAKER_MODEL_INPUT_LENGTH=16000
SPEAKER_SIMILARITY_THRESHOLD=0.78
